              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/claims/{{claim_id}}/submit",
              "host": ["{{base_url}}"],
              "path": ["claims", "{{claim_id}}", "submit"]
            }
          },
          "response": []
