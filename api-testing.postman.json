            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Medical Claim - Updated\",\n  \"claimAmount\": 55000\n}"
            },
            "url": {
              "raw": "{{base_url}}/claims/{{claim_id}}",
              "host": ["{{base_url}}"],
              "path": ["claims", "{{claim_id}}"]
            }
          },
          "response": []
