              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/claims/{{claim_id}}",
              "host": ["{{base_url}}"],
              "path": ["claims", "{{claim_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Update Claim (Draft Only)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
