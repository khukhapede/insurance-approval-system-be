		{
			"name": "1. Setup - Register & Login",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Response has accessToken', function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('accessToken');",
									"    pm.collectionVariables.set('user_token', response.accessToken);",
									"});",
									"",
									"pm.test('User role is correct', function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response.user.role).to.eql('user');",
									"    pm.collectionVariables.set('user_id', response.user.id);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"alice_user\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\",\n  \"fullName\": \"Alice User\",\n  \"role\": \"user\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "register"]
						}
					},
					"response": []
				},
				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
