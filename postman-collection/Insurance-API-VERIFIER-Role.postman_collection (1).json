{
	"info": {
		"name": "Insurance API - VERIFIER Role",
		"description": "Complete test flow for VERIFIER role including what they CAN and CANNOT do",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3000/api",
			"type": "string"
		},
		{
			"key": "verifier_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "verifier_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "claim_id",
			"value": "paste-claim-id-from-user-test",
